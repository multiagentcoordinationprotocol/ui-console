## E2E test environment — used by `npm run dev:e2e` to start the UI against real backends.
## Backends are started via: docker compose -f docker-compose.e2e.yml up -d --build --wait

NEXT_PUBLIC_MACP_UI_DEMO_MODE=false
EXAMPLE_SERVICE_BASE_URL=http://localhost:3100
CONTROL_PLANE_BASE_URL=http://localhost:3001
EXAMPLE_SERVICE_API_KEY=e2e-test
CONTROL_PLANE_API_KEY=e2e-test
JAEGER_BASE_URL=http://localhost:16686
