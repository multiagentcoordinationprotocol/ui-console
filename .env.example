# MACP UI Console — Environment Variables
# Copy this file to .env.local and fill in the values for your environment.

# ─── Demo mode ───────────────────────────────────────────────────────
# When true, the UI serves mock data without any backend connection.
# Set to "false" to connect to real Example Service and Control Plane.
NEXT_PUBLIC_MACP_UI_DEMO_MODE=true

# ─── Backend service URLs ────────────────────────────────────────────
# Example Service — scenario discovery, launch compilation, agent profiles
EXAMPLE_SERVICE_BASE_URL=http://localhost:3100

# Control Plane — run lifecycle, state, events, metrics, traces
CONTROL_PLANE_BASE_URL=http://localhost:3001

# ─── Backend authentication ──────────────────────────────────────────
# API key sent as x-api-key header to Example Service
EXAMPLE_SERVICE_API_KEY=

# API key sent as Bearer token to Control Plane
CONTROL_PLANE_API_KEY=

# ─── Observability ───────────────────────────────────────────────────
# Jaeger UI base URL for trace deep-links (server-side proxy + client links)
JAEGER_BASE_URL=http://localhost:16686
NEXT_PUBLIC_JAEGER_BASE_URL=http://localhost:16686

# ─── UI customization ───────────────────────────────────────────────
# Optional label shown in the topbar (e.g. "staging", "production")
NEXT_PUBLIC_MACP_ENVIRONMENT_LABEL=
