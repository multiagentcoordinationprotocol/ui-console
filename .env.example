# ──────────────────────────────────────────────────
# MACP UI Console — Environment Variables
# ──────────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
# cp .env.example .env.local

# ── Demo Mode ──────────────────────────────────────
# Set to "true" for full UI experience with mock data (no backend needed).
# Set to "false" to proxy to real Example Service and Control Plane.
NEXT_PUBLIC_MACP_UI_DEMO_MODE=true

# ── Example Service ────────────────────────────────
# Only required when demo mode is disabled.
EXAMPLE_SERVICE_BASE_URL=http://localhost:3000
EXAMPLE_SERVICE_API_KEY=

# ── Control Plane ──────────────────────────────────
# Only required when demo mode is disabled.
CONTROL_PLANE_BASE_URL=http://localhost:3001
CONTROL_PLANE_API_KEY=

# ── UI Customization ──────────────────────────────
# Optional label shown in the UI header (e.g., "staging", "production").
NEXT_PUBLIC_MACP_ENVIRONMENT_LABEL=
