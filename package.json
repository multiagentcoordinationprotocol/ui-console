{
  "name": "macp-ui-console",
  "version": "0.1.0",
  "private": true,
  "description": "Feature-rich Next.js orchestration and observability console for MACP.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css}\"",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "dev:demo": "NEXT_PUBLIC_MACP_UI_DEMO_MODE=true next dev",
    "dev:real": "NEXT_PUBLIC_MACP_UI_DEMO_MODE=false next dev",
    "dev:e2e": "npx env-cmd -f .env.e2e next dev",
    "local:up": "./scripts/local-stack.sh up",
    "local:down": "./scripts/local-stack.sh down",
    "local:status": "./scripts/local-stack.sh status"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@xyflow/react": "^12.10.1",
    "clsx": "^2.1.1",
    "github-slugger": "^2.0.0",
    "lucide-react": "^0.541.0",
    "mermaid": "^11.14.0",
    "next": "^16.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "env-cmd": "^11.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.1.0",
    "vitest": "^4.1.1"
  }
}
